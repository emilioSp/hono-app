{
  "name": "hono-app",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "LOG_LEVEL=debug node --watch --env-file=.env src/index.ts",
    "lint": "biome check --fix",
    "new:migration": "node --env-file=.env ./node_modules/.bin/knex migrate:make -x ts",
    "migrate": "node --env-file=.env ./node_modules/.bin/knex migrate:latest",
    "start": "node src/index.ts",
    "test": "node --env-file=.env ./node_modules/.bin/vitest run --coverage",
    "test:db:up": "docker compose up postgres -d --wait",
    "test:db:down": "docker compose down postgres",
    "test:ci": "npm run test:db:up && npm run migrate && npm run test; npm run test:db:down"
  },
  "imports": {
    "#app": "./src/app.ts",
    "#config": "./src/config.ts",
    "#error/*": "./src/error/*",
    "#logger": "./src/logger.ts",
    "#mapper/*": "./src/mapper/*",
    "#repository/*": "./src/repository/*",
    "#router/*": "./src/router/*",
    "#schema/*": "./src/schema/*",
    "#service/*": "./src/service/*"
  },
  "dependencies": {
    "@hono/node-server": "2.0.3",
    "@hono/zod-openapi": "1.4.0",
    "@hono/zod-validator": "0.8.0",
    "@scalar/hono-api-reference": "0.10.16",
    "@scalar/openapi-to-markdown": "0.5.17",
    "hono": "4.12.21",
    "knex": "3.2.10",
    "pg": "8.21.0",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
